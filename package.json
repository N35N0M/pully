  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "octokit": "^5.0.3"
  },
  "devDependencies": {
    "@octokit/webhooks-types": "^7.6.1",
    "@rollup/plugin-json": "^6.1.0",
