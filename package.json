{
  "name": "pully",
  "version": "2.0.2",
  "description": "A CI job that reports one-per-PR status messages to a slack channel, oneliner, constantly updated.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "package": "rolldown --config rollup.config.ts",
    "package:watch": "rolldown --config rollup.config.ts --watch"
  },
