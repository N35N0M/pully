  "bugs": {
    "url": "https://github.com/N35N0M/pully/issues"
  },
  "homepage": "https://github.com/N35N0M/pully#readme",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@slack/web-api": "^7.9.3",
    "octokit": "^5.0.3",
    "rolldown": "^1.0.0-rc.10"
  },
  "devDependencies": {
    "@octokit/webhooks-types": "^7.6.1",
    "@slack/types": "^2.15.0",
    "@types/node": "^24.2.1"
  }
}
